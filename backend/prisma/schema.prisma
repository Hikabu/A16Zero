// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  DRAFT
  PENDING_PAYMENT   // created, bonus not yet paid
  ACTIVE            // paid and live
  CLOSED_PENDING    // payment done but not published yet
  CLOSED            // finished, no longer accepting
}

enum MatchTier {
  TOP_MATCH
  POTENTIAL_MATCH
  GENERAL_MATCH
}

enum ShortlistStatus {
  PENDING
  REVIEWED
  CONTACTED
  REJECTED
}

enum ProofStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
}

model Company {
  id                 String     @id @default(uuid())
  name               String
  legalName          String? // exact registered business name 
  registrationNumber String?    @unique
  country            String
  isVerified         Boolean    @default(false)
  verifiedAt         DateTime?
  createdAt          DateTime   @default(now())

  walletAddress      String?    @unique
  privyId            String?    @unique

  jobPosts           JobPost[]

  @@map("companies")
}

model JobPost {
  id             String     @id @default(uuid())
  companyId      String
  title          String
  description    String
  location       String?
  employmentType String?    // full-time, part-time, contract
  bonusAmount    Decimal    @db.Decimal(10, 2)
  currency       String     @default("USD")
  status         JobStatus  @default(DRAFT)
  publishedAt    DateTime?
  closedAt       DateTime?
  createdAt      DateTime   @default(now())

  company        Company    @relation(fields: [companyId], references: [id])
  shortlists     Shortlist[]

  @@index([companyId])
  @@index([status])
  @@map("job_posts")
}

model Candidate {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String   @unique
  skills    Json     @default("[]")
  country   String?
  createdAt DateTime @default(now())

  talentProofs TalentProof[]
  shortlists   Shortlist[]

  @@map("candidates")
}

model TalentProof {
  id          String      @id @default(uuid())
  candidateId String
  proofType   String      // e.g. "github", "portfolio", "certification", "work_history"
  title       String
  url         String?
  verifiedBy  String?     // system or partner name
  status      ProofStatus @default(UNVERIFIED)
  score       Decimal?    @db.Decimal(5, 2)  // drives match tier calculation
  createdAt   DateTime    @default(now())

  candidate   Candidate   @relation(fields: [candidateId], references: [id])

  @@index([candidateId])
  @@map("talent_proofs")
}

model Shortlist {
  id         String          @id @default(uuid())
  jobPostId  String
  candidateId String
  matchTier  MatchTier
  status     ShortlistStatus @default(PENDING)
  notes      String?
  createdAt  DateTime        @default(now())

  jobPost    JobPost         @relation(fields: [jobPostId], references: [id])
  candidate  Candidate       @relation(fields: [candidateId], references: [id])

  @@unique([jobPostId, candidateId])  // one entry per candidate per job
  @@index([jobPostId, matchTier])
  @@map("shortlists")
}