// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  moduleFormat  = "cjs"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── COMPANY ──────────────────────────────────────────────────────────────────

model Company {
  id                 String  @id @default(uuid())
  name               String
  legalName          String? // exact registered business name
  logoUrl            String?
  website            String?
  description        String?
  registrationNumber String? @unique
  country            String

  // Trust & verification
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  isVerifiedPayer Boolean   @default(false)
  trustScore      Int       @default(0) // 0–100, application-maintained derived value

  // Denormalised counters — incremented by application logic, never by DB triggers
  totalJobsPosted      Int @default(0)
  totalEscrowsFunded   Int @default(0)
  totalEscrowsReleased Int @default(0)

  // Identity / auth
  email               String? @unique
  walletAddress       String? @unique
  smartAccountAddress String? @unique
  privyId             String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobPosts JobPost[]

  @@map("companies")
}

// ─── JOB POST ─────────────────────────────────────────────────────────────────

enum JobStatus {
  DRAFT
  PENDING_PAYMENT // created, escrow not yet funded
  ACTIVE // funded and live
  CLOSED_PENDING // payment done but not yet published
  CLOSED // finished, no longer accepting applications
}

enum Seniority {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum RoleType {
  BACKEND
  FRONTEND
  FULLSTACK
  INFRASTRUCTURE
  DATA_ML
  SMART_CONTRACT
  WEB3_BACKEND
  WEB3_FRONTEND
  WEB3_FULLSTACK
  DEFI_PROTOCOL
  SECURITY_WEB3
  SECURITY
  GENERALIST
}

enum EscrowStatus {
  UNFUNDED
  FUNDED
  RELEASED
  REFUNDED
}

model JobPost {
  id             String     @id @default(uuid())
  companyId      String
  title          String
  description    String
  location       String?
  employmentType String? // "full-time" | "part-time" | "contract"
  bonusAmount    Decimal    @db.Decimal(10, 2)
  currency       String     @default("USD")
  status         JobStatus  @default(DRAFT)
  roleType       RoleType?
  seniorityLevel Seniority?
  isWeb3Role     Boolean    @default(false)

  // Skills & requirements (structured at confirm-requirements time)
  requiredSkills          String[]  @default([])
  parsedRequirements      Json?
  dynamicWeights          Json? // { collaborationWeight, ownershipWeight, innovationWeight }
  requirementsConfirmedAt DateTime?

  // Escrow
  escrowId        BigInt?      @unique
  escrowAddress   String?      @unique
  candidateWallet String?
  escrowStatus    EscrowStatus @default(UNFUNDED)
  escrowFundedAt  DateTime?

  publishedAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company    Company     @relation(fields: [companyId], references: [id])
  shortlists Shortlist[]

  @@index([companyId, status, roleType])
  @@map("job_posts")
}

// ─── APPLICATION / SHORTLIST ──────────────────────────────────────────────────

enum FraudTier {
  CLEAN
  FLAGGED
  DISQUALIFIED
}

enum ShortlistStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  CONTACTED
  REJECTED
}

enum RiskLevel {
  LOW_RISK
  MEDIUM_RISK
  HIGH_RISK
  INSUFFICIENT_DATA
}

enum ConfidenceTier {
  FULL
  PARTIAL
  LOW
  MINIMAL
}

enum BehaviorPattern {
  REVIEW_HEAVY_SENIOR
  COMMIT_HEAVY_MIDLEVEL
  BALANCED_CONTRIBUTOR
  OSS_COLLABORATOR
  EARLY_CAREER
  RETURNING_DEVELOPER
  WEB3_SPECIALIST
}

enum FitTier {
  STRONG
  PROBE
  PASS
}

enum PipelineStage {
  APPLIED
  REVIEWED
  SHORTLISTED
  INTERVIEW_HR
  INTERVIEW_TECHNICAL
  INTERVIEW_FINAL
  OFFER
  HIRED
  REJECTED
}

model Shortlist {
  id          String          @id @default(uuid())
  jobPostId   String
  candidateId String
  status      ShortlistStatus @default(PENDING)

  // Scoring
  roleFitScore    Float            @default(0)
  fraudTier       FraudTier        @default(CLEAN)
  riskLevel       RiskLevel?
  confidenceTier  ConfidenceTier?
  behaviorPattern BehaviorPattern?
  fitTier         FitTier          @default(PASS)

  // Frozen snapshots — captured at apply-time, never mutated
  frozenScorecard Json? // Full AnalysisResult snapshot
  decisionCard    Json? // { verdict, strengths[], risks[], reputationNote }
  gapReport       Json? // GapReport object

  // Pipeline tracking
  pipelineStage        PipelineStage @default(APPLIED)
  pipelineStageHistory Json? // append-only log: [{ stage, changedAt, changedBy }]
  interviewQuestions   Json? // InterviewQuestionSet[]

  // Notes
  candidateNote String? @db.VarChar(280)
  hrNotes       String?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobPost   JobPost   @relation(fields: [jobPostId], references: [id])
  candidate Candidate @relation(fields: [candidateId], references: [id])

  @@unique([jobPostId, candidateId])
  @@index([jobPostId, roleFitScore(sort: Desc)])
  @@map("shortlists")
}

// ─── USER ─────────────────────────────────────────────────────────────────────

enum UserRole {
  CANDIDATE
  HR
  HR_ADMIN
  ORG_MANAGER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id       String  @id @default(uuid())
  email    String? @unique
  username String? @unique

  // Display name — stored on User so it is accessible without joining Candidate
  firstName String?
  lastName  String?
  name      String?

  role          UserRole      @default(CANDIDATE)
  accountStatus AccountStatus @default(ACTIVE)

  // Auth & security
  isEmailVerified Boolean  @default(false)
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String? // encrypted at rest (AES-256-GCM)
  mfaBackupCodes  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authAccounts AuthAccount[]
  candidate    Candidate?

  @@map("users")
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

enum AuthProvider {
  LOCAL
  GITHUB
  GOOGLE
}

model AuthAccount {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider     AuthProvider
  providerId   String
  passwordHash String?

  createdAt DateTime @default(now())

  @@unique([provider, providerId])
  @@map("auth_accounts")
}

// ─── CANDIDATE ────────────────────────────────────────────────────────────────
// Candidate holds profile data that is common to all career paths (bitmask).
// Path-specific data lives in the corresponding profile model (DeveloperProfile).

model Candidate {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Public profile
  avatarUrl String?
  bio       String? @db.VarChar(500)
  location  String? @db.VarChar(255)
  website   String? @db.VarChar(255)

  // Career path bitmask: 1 = DEVELOPER (extend as new paths are added)
  careerPath Int @default(1)

  // AI scorecard — path-agnostic, shape evolves per careerPath bitmask
  // Current shape (developer): { roleType, seniorityLevel, signals: Record<string, unknown>, overallFit }
  scorecard Json?

  // Cooldown for AI scorecard generation (path-agnostic)
  generateCooldownUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devProfile   DeveloperProfile?
  shortlist    Shortlist[]
  analysisJobs AnalysisJob[]
  vouches      Vouch[]

  @@map("candidates")
}

// ─── DEVELOPER PROFILE ────────────────────────────────────────────────────────
// Owned 1-to-1 by Candidate. All developer-specific signals and scoring live here.
// Linked by candidateId (Candidate.id) — not by userId — to keep the FK chain clean.

model DeveloperProfile {
  id          String    @id @default(uuid())
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Per-source sync cooldowns
  githubCooldownUntil DateTime?
  walletCooldownUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  githubProfile GithubProfile?
  web3Profile   Web3Profile?

  @@map("developer_profiles")
}

// ─── GITHUB PROFILE ───────────────────────────────────────────────────────────

enum SyncStatus {
  NOT_SYNCED
  CONNECT_REQUEST // OAuth flow initiated
  CONNECT_SUCCESS
  SYNC_REQUEST
  SYNC_FETCH_REQUEST
  SYNC_FETCH_SUCCESS
  SYNC_SUCCESS
  SYNC_FAILED
}

model GithubProfile {
  id                 String           @id @default(uuid())
  developerProfileId String           @unique
  developerProfile   DeveloperProfile @relation(fields: [developerProfileId], references: [id], onDelete: Cascade)

  githubUsername String   @unique
  githubUserId   String   @unique
  encryptedToken String // AES-256-GCM "v1:<iv>:<tag>:<cipher>"
  scopes         String[] @default([])

  syncStatus   SyncStatus @default(NOT_SYNCED)
  syncProgress Int        @default(0)
  syncError    String?
  lastSyncAt   DateTime?

  rawDataSnapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("github_profiles")
}

// ─── WEB3 PROFILE ─────────────────────────────────────────────────────────────
// Opt-in. Wallet submitted by the candidate.
// Solana signals use RPC-native methods (no Etherscan equivalent for Solana).

model Web3Profile {
  id                 String           @id @default(uuid())
  developerProfileId String           @unique
  developerProfile   DeveloperProfile @relation(fields: [developerProfileId], references: [id], onDelete: Cascade)

  solanaAddress     String?
  // [{ chain, contractAddress, txHash, attributionMethod, confidence }]
  verifiedContracts Json?
  onChainMetrics    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("web3_profiles")
}

// ─── VOUCHES ──────────────────────────────────────────────────────────────────

model Vouch {
  id String @id @default(uuid())

  // FK to Candidate, not to GithubProfile — vouches survive profile resets
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Voucher identity — wallet proving on-chain identity
  voucherWallet String
  message       String @db.VarChar(500)
  txSignature   String @unique

  // Weight & lifecycle
  weight   String  @default("standard") // "verified" | "standard" | "new"
  isActive Boolean @default(true)
  flag     String? // "cluster_detected" | null

  confirmedAt DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?

  @@unique([candidateId, voucherWallet])
  @@index([candidateId, isActive, expiresAt])
  @@index([voucherWallet, isActive, expiresAt])
  @@map("vouches")
}

// ─── ANALYSIS JOB ─────────────────────────────────────────────────────────────
// Tracks async analysis tasks. Linked to Candidate by candidateId (Candidate.id).

model AnalysisJob {
  id          String     @id @default(uuid())
  candidateId String?
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  status   String  @default("pending") // "pending" | "processing" | "completed" | "failed"
  progress Int     @default(0)
  input    Json // { githubUsername, walletAddress, mode, useGithubCache }
  result   Json?
  error    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("analysis_jobs")
}

// ─── CACHE ────────────────────────────────────────────────────────────────────

model CachedResult {
  id        String   @id @default(cuid())
  cacheKey  String   @unique // "analysis:{username}" | "analysis:{username}:{walletAddress}"
  result    Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("cached_results")
}
