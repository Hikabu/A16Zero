// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
    url      = env("DATABASE_URL")
}


// ─── Multi-Tenancy ───────────────────────────────────────────
// PostgreSQL RLS enforced via SET app.tenant_id before every query.
// Prisma middleware injects SET LOCAL app.tenant_id = $tenantId.

model Organisation {
  id              String   @id @default(uuid())
  name            String
  atsConnector    Json?    // { provider, accessToken (encrypted), refreshToken }
  priorBlendRatio Float    @default(1.0) // 1.0 = 100% platform prior; shifts as outcomes accumulate
  createdAt       DateTime @default(now())
}

// ─── User Hierarchy ──────────────────────────────────────────
enum UserRole { 
  CANDIDATE
  HR  
  HR_ADMIN  
  ORG_MANAGER  
  ADMIN 
}

enum AccountStatus {
  ACTIVE  
  SUSPENDED
}

model User {
  id            String        @id @default(uuid())
  email         String?        @unique
  username      String?       @unique

  firstName     String?
  lastName      String?

  role          UserRole      @default(CANDIDATE)
  accountStatus AccountStatus @default(ACTIVE)

  isEmailVerified Boolean      @default(false)
  mfaEnabled      Boolean      @default(false)
  mfaSecret       String?      // Should be encrypted at rest
  mfaBackupCodes  String[]     @default([])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  authAccounts  AuthAccount[]
  candidate     Candidate?
}

// ─── User AUTH  ──────────────────────────────────────────
enum AuthProvider {
  LOCAL
  GITHUB
  GOOGLE
}

model AuthAccount {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider    AuthProvider
  providerId  String

  passwordHash String?

  createdAt   DateTime @default(now())
  @@unique([provider, providerId])
}

// ─── User Type: CANDIDATE  ──────────────────────────────────────────


model Candidate {
  id           String             @id @default(uuid())
  userId       String             @unique
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio          String?            @db.VarChar(500)
  careerPath   Int                @default(1) // bitmask: 1=DEVELOPER
  devProfile   DeveloperCandidate?
  applications Application[]
  createdAt    DateTime           @default(now())
}

model DeveloperCandidate {
  id            String            @id @default(uuid())
  candidateId   String            @unique
  candidate     Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  githubProfile GithubProfile?
  web3Profile   Web3Profile?
  signals       CandidateSignals?
  snapshot      DeveloperSnapshot?
  timeline      CareerTimeline?
  claims        CandidateClaim[]
  createdAt     DateTime          @default(now())
}

// ─── GitHub Profile ──────────────────────────────────────────
enum SyncStatus { 
  PENDING  
  RUNNING  
  DONE  
  FAILED 
}

model GithubProfile {
  id               String             @id @default(uuid())
  devCandidateId   String             @unique
  devCandidate     DeveloperCandidate @relation(fields: [devCandidateId], references: [id], onDelete: Cascade)
  githubUsername   String             @unique
  githubUserId     String             @unique
  encryptedToken   String             // AES-256-GCM "v1:<iv>:<tag>:<cipher>"
  scopes           String[]
  lastSyncedAt     DateTime?
  syncStatus       SyncStatus         @default(PENDING)
  syncProgress     Int                @default(0)
  rawDataSnapshot  Json?
  createdAt        DateTime           @default(now())
}

// ─── Web3 Profile (opt-in) ───────────────────────────────────
// Wallet address submitted by candidate — no signature verification needed.
// Solana signals use RPC-native methods; there is no Solana equivalent of Etherscan.

model Web3Profile {
  id               String             @id @default(uuid())
  devCandidateId   String             @unique
  devCandidate     DeveloperCandidate @relation(fields: [devCandidateId], references: [id], onDelete: Cascade)
  evmAddress       String?
  solanaAddress    String?
  // [{ chain, contractAddress, txHash, attributionMethod, confidence }]
  verifiedContracts Json?
  onChainMetrics    Json?
  createdAt         DateTime          @default(now())
}

// ─── Signals ─────────────────────────────────────────────────
enum FraudTier { 
  CLEAN  
  FLAGGED  
  DISQUALIFIED 
}
enum ConfidenceTier { 
  FULL  
  PARTIAL  
  LOW  
  MINIMAL 
}
enum RiskLevel { 
  LOW_RISK  
MEDIUM_RISK 
HIGH_RISK  
INSUFFICIENT_DATA 
}

enum BehaviorPattern {
  REVIEW_HEAVY_SENIOR
  COMMIT_HEAVY_MIDLEVEL
  BALANCED_CONTRIBUTOR
  OSS_COLLABORATOR
  EARLY_CAREER
  RETURNING_DEVELOPER
  WEB3_SPECIALIST
}

enum Seniority { 
  JUNIOR  
  MID  
  SENIOR  
  LEAD 
}

enum RoleType {
  BACKEND  
  FRONTEND  
  FULLSTACK  
  INFRASTRUCTURE  
  DATA_ML
  SMART_CONTRACT 
  WEB3_BACKEND  
  WEB3_FRONTEND 
  WEB3_FULLSTACK
  DEFI_PROTOCOL 
  SECURITY_WEB3  
  SECURITY 
  GENERALIST
}

model CandidateSignals {
  id                       String             @id @default(uuid())
  devCandidateId           String             @unique
  devCandidate             DeveloperCandidate @relation(fields: [devCandidateId], references: [id], onDelete: Cascade)
  computedAt               DateTime           @default(now())

  // Activity
  activeWeeksRatio         Float?
  prThroughput90d          Float?
  commitConsistencyScore   Float?
  avgCommitsPerMonth       Float?
  commitLongevityMonths    Int?
  privateOrgActivity       Boolean            @default(false)
  verifiedEmployers        Json?
  verifiedPrivateMonths    Int                @default(0)

  // Code Quality
  testPresenceScore        Float?
  cicdScore                Float?
  hygieneScore             Float?
  securityScore            Float?
  prAcceptanceRate         Float?
  changeRequestFrequency   Float?
  reworkRatio              Float?

  // Complexity / Ownership
  ownershipScore           Float?
  refactorRatio            Float?
  docScore                 Float?
  repoLongevityScore       Float?

  // Collaboration
  reviewScore              Float?
  reviewDepth              Float?
  reviewCommitRatio        Float?
  externalPrRatio          Float?
  issueScore               Float?
  architecturePrScore      Float?

  // Architecture
  depHygieneScore          Float?
  cicdStagesScore          Float?

  // Growth
  stackEvolutionScore      Float?
  growthTrajectoryScore    Float?
  newLanguagesAdopted      Int?

  // Impact
  starsOnOriginalRepos     Int?
  forksOnOriginalRepos     Int?
  prestigeRepoContribs     Int                @default(0)
  primaryLanguageDepth     Float?
  languageBreadth5yr       Int?

  // Web3 (JSONB — scored only for Web3 RoleTypes)
  web3Signals              Json?

  // Fraud
  fraudScore               Float              @default(0)
  fraudFlags               Json               @default("[]")
  fraudTier                FraudTier          @default(CLEAN)

  // Data completeness
  dataCoveragePercent      Float              @default(0)
  privacyAdjustmentApplied Boolean           @default(false)
  ecosystemCohort          String?
  effectivePillarWeights   Json?              // after rebalancing — shown to HR

  // Classification
  inferredSeniority        Seniority?
  seniorityConfidence      Float?
  inferredRole             RoleType?
  roleConfidence           Float?
  behaviorPattern          BehaviorPattern?
  behaviorConfidence       Float?

  // Confidence
  confidenceTier           ConfidenceTier?
  riskLevel                RiskLevel?
  confidenceScore          Float?
  confidenceCaveats        Json               @default("[]")

  // Temporal
  peakCareerScore          Float?             // best 24-month window
  recentScore              Float?             // last 6 months
  trendSignal              String?            // ASCENDING | STABLE | DECLINING | RETURNING

  // Percentile
  ecosystemPercentile      Float?
  percentileLabel          String?            // "Top 15% TypeScript developers"

  // Pillar summaries (0–100)
  pillarActivity           Float?
  pillarQuality            Float?
  pillarComplexity         Float?
  pillarCollaboration      Float?
  pillarArchitecture       Float?
  pillarGrowth             Float?
  pillarWeb3               Float?

  // Caveats
  notObservable            Json               @default("[]") // Unknowns layer
  languageDistribution     Json?
  topRepos                 Json?
}

// ─── DeveloperSnapshot (first-class model, ADR-013) ──────────
model DeveloperSnapshot {
  id             String             @id @default(uuid())
  devCandidateId String             @unique
  devCandidate   DeveloperCandidate @relation(fields: [devCandidateId], references: [id], onDelete: Cascade)
  role           RoleType
  roleConfidence Float
  seniority      Seniority
  seniorityConf  Float
  summary        String             // 1-2 sentences from BehaviorPattern + top capabilities
  riskLevel      RiskLevel
  decisionSignal String             // PROCEED | REVIEW | REJECT
  generatedAt    DateTime           @default(now())
}

// ─── CareerTimeline (first-class model) ──────────────────────
model CareerTimeline {
  id               String             @id @default(uuid())
  devCandidateId   String             @unique
  devCandidate     DeveloperCandidate @relation(fields: [devCandidateId], references: [id], onDelete: Cascade)
  phases           Json               // [{ phase, startDate, endDate, signals }]
  trajectory       String             // ASCENDING | STABLE | DECLINING | RETURNING
  gapEvents        Json               @default("[]") // [{ startDate, endDate, durationDays }]
  peakWindow       Json?              // { startDate, endDate, score }
  contextInference Json?              // workEnvironment, collaborationStyle, teamVsSolo
  generatedAt      DateTime           @default(now())
}

// ─── Claims ──────────────────────────────────────────────────
enum ClaimType { 
  ACTIVITY
  IMPACT  
  COLLABORATION 
  QUALITY  
  BEHAVIOR  
  GROWTH  
  WEB3 
}

model CandidateClaim {
  id                String             @id @default(uuid())
  devCandidateId    String
  devCandidate      DeveloperCandidate @relation(fields: [devCandidateId], references: [id], onDelete: Cascade)
  claimType         ClaimType
  claimKey          String
  description       String
  supportingSignals Json
  evidenceLinks     Json
  confidence        Float
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  @@index([devCandidateId, isActive])
}

// ─── Jobs (read-only stub — HR team owns CRUD; same DB) ──────
model Job {
  id              String        @id @default(uuid())
  tenantId        String
  orgId           String
  title           String
  roleType        RoleType
  seniorityLevel  Seniority?
  requiredSignals Json?
  weightOverrides Json?
  historicalWeight Float?       @default(0.7)
  recentWeight     Float?       @default(0.3)
  status          String        @default("OPEN")
  createdAt       DateTime      @default(now())
  closesAt        DateTime?
  applications    Application[]
  @@index([tenantId, status, roleType])
}

// ─── Applications ─────────────────────────────────────────────
enum ApplicationStatus { 
  PENDING 
  REVIEWED 
  SHORTLISTED  
  REJECTED  
  HIRED 
}

enum FitTier { 
  STRONG  
  PROBE  
  PASS 
}

enum ContestationStatus { 
  NONE  
  PENDING  
  REVIEWED  
  ACTIONED  
  DISMISSED 
}

model Application {
  id                    String            @id @default(uuid())
  tenantId              String
  jobId                 String
  job                   Job               @relation(fields: [jobId], references: [id])
  candidateId           String
  candidate             Candidate         @relation(fields: [candidateId], references: [id])
  appliedAt             DateTime          @default(now())
  status                ApplicationStatus @default(PENDING)
  // Frozen at apply-time (immutable)
  decisionCard          Json              // { signal, riskLevel, strengths[], risks[] }
  gapReport             Json              // full GapReport interface
  capabilityStatements  Json
  confidenceEnvelope    Json
  behaviorPattern       BehaviorPattern?
  temporalProfile       Json?
  roleFitScore          Float
  fitTier               FitTier
  fraudTier             FraudTier
  candidateNote         String?           @db.VarChar(280)
  hrNotes               String?
  // Contestation (GDPR Article 22)
  contestation          Json?             // { signalKey, candidateReason, raisedAt }
  contestationStatus    ContestationStatus @default(NONE)
  contestationResolvedAt DateTime?
  contestationActorId   String?
  @@unique([jobId, candidateId])
  @@index([tenantId, jobId, roleFitScore(sort: Desc)])
}

// ─── Outcomes & Learning ─────────────────────────────────────
model HireOutcome {
  id                           String   @id @default(uuid())
  tenantId                     String
  applicationId                String   @unique
  wasHired                     Boolean
  performanceRating            Float?   // 0-5 at 90 days
  behaviorPatternAtDecision    BehaviorPattern?
  temporalProfileSnapshot      Json?
  capabilityStatementsAtDecision Json?
  confidenceAtDecision         Float?
  roleFitScore                 Float?
  pillarScores                 Json?
  recordedAt                   DateTime @default(now())
  @@index([tenantId, wasHired])
}

model PlatformPrior {
  id              String          @id @default(uuid())
  behaviorPattern BehaviorPattern
  hireRate        Float
  avgPerformance90d Float?
  sampleSize      Int
  computedAt      DateTime        @default(now())
  @@unique([behaviorPattern])
}

// ─── Benchmarks ───────────────────────────────────────────────
model BenchmarkCohort {
  id                   String   @id @default(uuid())
  cohortKey            String   @unique // e.g. "typescript_node_web"
  pillarDistributions  Json     // { activity: { p25, p50, p75, p90 }, ... }
  sampleSize           Int
  computedAt           DateTime @default(now())
}

// ─── HR Views ────────────────────────────────────────────────
model HrSavedView {
  id           String   @id @default(uuid())
  tenantId     String
  orgId        String
  userId       String
  jobId        String?
  name         String
  filterConfig Json
  createdAt    DateTime @default(now())
}

// ─── ROI & Fairness ──────────────────────────────────────────
model RoiSnapshot {
  id                   String   @id @default(uuid())
  tenantId             String
  orgId                String
  periodStart          DateTime
  periodEnd            DateTime
  avgScreenMinutes     Float?
  interviewOfferRatio  Float?
  timeToFirstDecision  Float?
  costDelta            Float?
  createdAt            DateTime @default(now())
}

model FairnessReport {
  id          String   @id @default(uuid())
  tenantId    String
  orgId       String
  quarter     String   // "2026-Q2"
  reportPdf   Bytes?
  flagCount   Int      @default(0)
  generatedAt DateTime @default(now())
}

// ─── Audit Log ────────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  entityType String
  entityId   String
  action     String
  actorId    String?
  before     Json?
  after      Json?
  timestamp  DateTime @default(now())
  @@index([tenantId, entityId, timestamp])
}